def analyze_comments_sentiment(comments):
    """分析评论情感倾向"""
    if not comments:
        return "数据不足"
    
    positive_words = ['好', '支持', '赞成', '喜欢', '优秀', '棒', '强']
    negative_words = ['差', '反对', '讨厌', '垃圾', '烂', '弱', '难']
    
    positive_count = 0
    negative_count = 0
    
    for comment in comments:
        for word in positive_words:
            if word in comment:
                positive_count += 1
                break
        for word in negative_words:
            if word in comment:
                negative_count += 1
                break
    
    if positive_count > negative_count:
        return "偏正面"
    elif negative_count > positive_count:
        return "偏负面"
    else:
        return "中性平衡"

def generate_intelligent_fallback(topic, hot_searches):
    """智能备用内容生成"""
    fallback_content = f"""📢 **#{topic}# 热点关注**

"""
    
    if hot_searches:
        fallback_content += f"🔥 **关联热点**: {hot_searches[0]['title']}\n\n"
    
    fallback_content += f"""💡 **内容分享**
关于{topic}，这是一个值得关注的话题。

基于当前社会环境和网络热点，这个话题体现了：
• 时代发展的某些特征
• 人们关注的核心问题
• 潜在的发展趋势

🤔 **思考交流**
每个话题都有其深度和广度，值得我们理性讨论和深入思考。

#热点话题 #理性讨论 #深度思考

你对此话题有什么看法？欢迎参与讨论！"""
    
    return fallback_content
