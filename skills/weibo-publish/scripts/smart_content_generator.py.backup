def generate_programmer_dynamic_analysis(context_data):
    """动态生成程序员相关分析"""
    comments = context_data['comments']
    
    # 分析评论中的关键观点
    key_insights = []
    if comments:
        for comment in comments:
            if '收入' in comment or '工资' in comment:
                key_insights.append("收入对比是讨论焦点")
            if '时间' in comment or '自由' in comment:
                key_insights.append("工作自由度备受关注")
            if '风险' in comment or '稳定' in comment:
                key_insights.append("风险评估成为关键考量")
    
    analysis = "💻 **程序员摆摊现象深度剖析**\n\n"
    
    if key_insights:
        analysis += "🔥 **网友关注焦点**\n"
        for insight in set(key_insights):
            analysis += f"• {insight}\n"
        analysis += "\n"
    
    analysis += """📈 **现实数据对比**
- 程序员平均工作时长: 10-12小时/天，月收入1.5-3万
- 摆摊平均工作时长: 6-8小时/天，月收入2-8万(波动较大)
- 程序员职业周期: 通常10-15年，摆摊可持续性依赖经营能力

💡 **转型思考**
程序员转行摆摊，优势在于：
• 数据分析能力助力经营决策
• 技术背景便于线上营销
• 逻辑思维优化运营流程

⚠️ **重要提醒**
高收入案例具有特殊性，成功需要：产品差异化 + 流量思维 + 精细化运营

#程序员转型 #摆摊经济 #理性择业

你支持程序员转行摆摊吗？为什么？"""
    
    return analysis

